# 知册多模态客服智能体 — 环境变量模板
# 用法：复制本文件为 .env（放在包根目录，与 question_public.csv 同级），填入你的密钥。
# 代码通过 g1_pipeline.load_env() 直接读取本包根目录的 .env（不读系统环境变量）。
# ⚠️ 切勿把含真实密钥的 .env 提交到代码仓库或公开分发。

# ---------- 文本生成后端（OpenAI 兼容网关；用于 route/二因子作答）----------
TEXT_API_BASE_URL=https://your-openai-compatible-gateway/v1
TEXT_API_KEY=sk-xxxxxxxxxxxxxxxx
TEXT_MODEL=deepseek-chat
# 实测最优生成模型为 claude-opus-4-8 档；网关需 OpenAI 兼容 /chat/completions。

# ---------- 向量嵌入后端（用于章节检索 section_affinity）----------
EMBEDDING_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxx
EMBEDDING_MODEL=text-embedding-v3

# ---------- 评分/仲裁模型（Qwen；用于检索仲裁 adjudicate 与离线自评/回测）----------
JUDGE_API_BASE_URL=https://your-qwen-gateway/v1
JUDGE_API_KEY=sk-xxxxxxxxxxxxxxxx
JUDGE_MODEL=qwen3.5-27b

# ---------- 视觉后端（可选；多模态图片理解，见 README §多模态）----------
VISION_API_BASE_URL=
VISION_API_KEY=
VISION_MODEL=

# ---------- API 服务鉴权（生产部署建议设置；/chat 校验 Authorization: Bearer <该值>）----------
KAFU_API_TOKEN=
